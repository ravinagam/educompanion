# Test Supabase project (separate from prod — create a new project at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-test-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-test-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-key

# Anthropic — use a low-limit key or the same key (E2E tests avoid real AI calls where possible)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Voyage AI (embeddings on upload)
VOYAGE_API_KEY=your-voyage-api-key

# Sarvam AI (TTS — can leave blank to use browser TTS fallback in tests)
SARVAM_API_KEY=

# Test accounts (created manually in the test Supabase project)
TEST_STUDENT_EMAIL=student@test.easestudy.in
TEST_STUDENT_PASSWORD=TestPass123!
TEST_ADMIN_EMAIL=admin@test.easestudy.in
TEST_ADMIN_PASSWORD=TestPass123!

# Sample chapter seeded in test project for E2E tests
TEST_SAMPLE_CHAPTER_ID=

NEXT_PUBLIC_APP_URL=http://localhost:3006
